#!/usr/bin/env bash
# teach/ell -- dev shell, tasks, push helper. one file, no /etc.

help() {
  cat <<'EOF'
ell -- teach/ dev shell + task runner

usage:
  ell                launch dev shell (default)
  ell sh             same as no args
  ell -h | help      show this help
  ell push           prompt for msg; commit -am + push + status
  ell the            print config *the*
  ell tree           plain-budget tree on auto93.csv
  ell atree          active-learning tree on auto93.csv
  ell active         20 train/test active-learning runs
  ell check          run wise.lisp invariant tests
  ell nb [FILE]      naive bayes (defaults to heart.c.csv)
  ell diabetes       NB on diabetes.csv
  ell soybean        NB on soybean.csv
  ell ncheck         run nb.lisp assertions
  ell --pdf OUT IN   render IN.lisp to OUT.pdf via a2ps

inside the shell:
  vi FILE            nvim with minimal init
  blat FILE          bat with clojure highlighting + Monokai theme
  ls grep            colorized
  PATH               teach/ prepended so 'ell <cmd>' works anywhere
EOF
}

#--------------------------------------------------------------------
push() {
  read -rp "Reason? " msg
  git commit -am "$msg" && git push && git status
}

tree()  { sbcl --script wise.lisp -f ../auto93.csv --tree   ; }
atree() { sbcl --script wise.lisp -f ../auto93.csv --atree  ; }
active(){ sbcl --script wise.lisp -f ../auto93.csv --active ; }
the()   { sbcl --script wise.lisp --the                     ; }
check() { sbcl --script wise.lisp -f ../auto93.csv --check  ; }

nb()      { sbcl --script nb.lisp -f "${1:-$HOME/gits/timm/moot/classify/heart.c.csv}" --nb ; }
diabetes(){ sbcl --script nb.lisp -f $HOME/gits/timm/moot/classify/diabetes.csv --nb ; }
soybean() { sbcl --script nb.lisp -f $HOME/gits/timm/moot/classify/soybean.csv --nb ; }
ncheck()  { sbcl --script nb.lisp --check ; }

pdf() {
  local out=$1 in=$2 ssh chars=${Chars:-70}
  [[ -z $out || -z $in ]] && {
    echo "usage: ell --pdf OUT.pdf IN.lisp" >&2; exit 1; }
  ssh=$(dirname "$(realpath "$0")")/../etc/def.ssh
  [[ -f $ssh ]] || {
    echo "ell: missing $ssh" >&2; exit 1; }
  mkdir -p "$(dirname "$out")"
  echo "pdf-ing $out ..."
  a2ps --pretty-print="$ssh" -Br --quiet --landscape \
       --pro=color --chars-per-line="$chars" \
       --line-numbers=1 --borders=no --columns=3 \
       -M letter -o - "$in" | ps2pdf - "$out"
  command -v open >/dev/null && open "$out"
}

#--------------------------------------------------------------------
shell() {
  write_nvim_init
  local rc
  rc=$(mktemp)
  cat > "$rc" <<EOF
# aliases
alias ls='ls --color'
alias grep='grep --color=auto'
alias blat='bat -l clojure --theme="Nord"'
alias vi='nvim -u $NVIM_INIT'

# env -- prepend teach/ to PATH so 'ell <cmd>' works anywhere
export PATH="$(dirname "$(realpath "$0")"):\$PATH"
export EDITOR=nano
export HISTSIZE=10000
export HISTFILESIZE=20000

# prompt
bold=\$(tput bold); col0=\$(tput sgr0); col1=\$(tput setaf 6); col2=\$(tput setaf 3)
branch() { git branch 2>/dev/null | awk '/^\*/ {print \$2}'; }
dirty()  { [[ -n \$(git status -s 2>/dev/null) ]] && echo "*"; }
PROMPT_COMMAND='PS1="🧩\[\${bold}\${col1}\]\$(basename "\$(dirname "\$PWD")")/\$(basename "\$PWD")\[\${col0}\] \[\${col2}\]\$(branch)\$(dirty)\[\${col0}\] ▶ "'

# banner
printf '\033[H\033[2J\033[3J\033[1;33m\n'
cat <<'ART'
       ___
      (o,o)
      {\`"'}
      -"-"-
ART
printf '\033[1;36m\n'
printf " 'What we have to learn to\n"
printf "  do, we learn by doing.'\n"
printf '            -- Aristotle\n'
printf '\033[0m\n'
EOF
  bash --init-file "$rc" -i
  rm -f "$rc"
}

# --------------------------------------------------------------
# nvim init (dumped to /tmp on demand by shell())
# --------------------------------------------------------------
NVIM_INIT="${TMPDIR:-/tmp}/teach-nvim-init.lua"

write_nvim_init() {
  cat > "$NVIM_INIT" <<'LUA'
-- netrw
vim.g.netrw_banner = 0
vim.g.netrw_liststyle = 3
vim.g.netrw_browse_split = 4
vim.g.netrw_winsize = 15

-- ui / editing
vim.opt.number = true
vim.opt.relativenumber = true
vim.opt.cursorline = true
vim.opt.mouse = "a"
vim.opt.clipboard = "unnamedplus"
vim.opt.ignorecase = true
vim.opt.smartcase = true
vim.opt.expandtab = true
vim.opt.tabstop = 2
vim.opt.shiftwidth = 2
vim.opt.splitright = true
vim.opt.splitbelow = true

-- undo
vim.opt.undofile = true
vim.opt.undodir = vim.fn.expand("~/.vim/undo")

-- statusline
vim.opt.statusline = "%#StatusLine# ▶ %f %m%r%=%y ❖ %l:%c ❖ %p%% "
vim.opt.laststatus = 2

-- keymaps
vim.keymap.set("n", "Q", ":quitall<CR>", { noremap = true, silent = true })
vim.keymap.set("n", "<leader>s", ":set spell!<CR>", { silent = true })

-- colors
vim.cmd.colorscheme("sorbet")

-- lisp indent: vim built-in + extra forms via lispwords
vim.api.nvim_create_autocmd("FileType", {
  pattern = "lisp",
  callback = function()
    vim.bo.lisp = true
    vim.bo.lispwords =
      vim.bo.lispwords .. ",defmethods,defeg,let+"
  end,
})
LUA
}

# --------------------------------------------------------------
# dispatch
# --------------------------------------------------------------
case "${1:-sh}" in
  -h|--help|help) help ;;
  push)           push ;;
  tree)           tree ;;
  atree)          atree ;;
  active)         active ;;
  the)            the  ;;
  check)          check ;;
  nb)             nb "$2" ;;
  diabetes)       diabetes ;;
  soybean)        soybean ;;
  ncheck)         ncheck ;;
  --pdf)          pdf "$2" "$3" ;;
  sh|"")          shell ;;
  *) echo "ell: unknown command '$1'" >&2; help; exit 1 ;;
esac
